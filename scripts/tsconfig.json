{
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"types": ["@types/bun"],
		// Operator-run bun scripts resolve workspace packages by name at runtime; map the
		// one(s) they import to source so `tsc` resolves them the same way (no built dist).
		"paths": {
			"@propustka/core": ["../packages/core/src/index.ts"]
		}
	},
	"include": ["*.ts"]
}
